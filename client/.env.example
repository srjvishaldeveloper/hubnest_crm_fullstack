# ─── Client (Next.js) Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Backend API base URL (no trailing slash)
# Local:  http://localhost:5000/api/v1
# Docker: http://localhost:5000/api/v1
# Prod:   https://hubnest.in/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# JWT secret — must match the server's JWT_SECRET exactly
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars

# Google OAuth Client ID
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
