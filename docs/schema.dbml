  }
}

Table "tasks" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "user_id" uuid [not null]
  "lead_id" uuid
  "type" "character varying(20)" [not null]
  "title" "character varying(255)" [not null]
  "scheduled_at" timestamp
  "completed_at" timestamp
  "status" "character varying(20)" [not null, default: `'Pending'::charactervarying`]
  "priority" "character varying(10)" [not null, default: `'Medium'::charactervarying`]
  "notes" text
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((priority)::text = ANY ((ARRAY['High'::character varying, 'Medium'::character varying, 'Low'::character varying])::text[]))` [name: 'tasks_priority_check']
    `((status)::text = ANY ((ARRAY['Pending'::character varying, 'Done'::character varying, 'Missed'::character varying])::text[]))` [name: 'tasks_status_check']
    `((type)::text = ANY ((ARRAY['Call'::character varying, 'Meeting'::character varying, 'Follow-up'::character varying, 'Email'::character varying])::text[]))` [name: 'tasks_type_check']
  }

  Indexes {
    lead_id [type: btree, name: "idx_tasks_lead_id"]
    status [type: btree, name: "idx_tasks_status"]
    tenant_id [type: btree, name: "idx_tasks_tenant_id"]
    user_id [type: btree, name: "idx_tasks_user_id"]
  }
}

Table "tax_records" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "tax_type" "character varying(50)" [not null]
  "amount" numeric(12,2) [not null, default: 0]
  "period" "character varying(20)" [not null]
  "status" "character varying(20)" [not null, default: `'Pending'::charactervarying`]
  "filed_at" timestamp
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((status)::text = ANY ((ARRAY['Pending'::character varying, 'Filed'::character varying, 'Paid'::character varying, 'Overdue'::character varying])::text[]))` [name: 'tax_records_status_check']
    `((tax_type)::text = ANY ((ARRAY['GST'::character varying, 'Income Tax'::character varying, 'TDS'::character varying, 'Professional Tax'::character varying, 'Other'::character varying])::text[]))` [name: 'tax_records_tax_type_check']
  }

  Indexes {
    status [type: btree, name: "idx_tax_records_status"]
    tenant_id [type: btree, name: "idx_tax_records_tenant_id"]
  }
}

Table "team_members" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "team_id" uuid [not null]
  "user_id" uuid [not null]
  "tenant_id" uuid [not null]
  "joined_at" timestamp [not null, default: `now()`]

  Indexes {
    (team_id, user_id) [unique, name: "team_members_team_id_user_id_key"]
    team_id [type: btree, name: "idx_team_members_team"]
    user_id [type: btree, name: "idx_team_members_user"]
  }
}

Table "teams" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "manager_id" uuid [not null]
  "name" "character varying(100)" [not null]
  "description" text
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Indexes {
    (tenant_id, name) [unique, name: "teams_tenant_id_name_key"]
    manager_id [type: btree, name: "idx_teams_manager_id"]
    tenant_id [type: btree, name: "idx_teams_tenant_id"]
  }
}

Table "tenant_subscriptions" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "plan_id" uuid [not null]
  "status" "character varying(20)" [not null, default: `'active'::charactervarying`]
  "billing_cycle" "character varying(20)" [not null, default: `'monthly'::charactervarying`]
  "started_at" timestamp [not null, default: `now()`]
  "expires_at" timestamp
  "cancelled_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((billing_cycle)::text = ANY ((ARRAY['monthly'::character varying, 'yearly'::character varying])::text[]))` [name: 'tenant_sub_billing_check']
    `((status)::text = ANY ((ARRAY['active'::character varying, 'cancelled'::character varying, 'expired'::character varying, 'trial'::character varying])::text[]))` [name: 'tenant_sub_status_check']
  }

  Indexes {
    plan_id [type: btree, name: "idx_tenant_subscriptions_plan"]
    status [type: btree, name: "idx_tenant_subscriptions_status"]
    tenant_id [type: btree, name: "idx_tenant_subscriptions_tenant"]
  }
}

Table "tenants" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "name" "character varying(255)" [not null]
  "schema_name" "character varying(100)" [unique, not null]
  "status" "character varying(20)" [not null, default: `'Active'::charactervarying`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((status)::text = ANY ((ARRAY['Active'::character varying, 'Inactive'::character varying, 'Suspended'::character varying])::text[]))` [name: 'tenants_status_check']
  }

  Indexes {
    schema_name [type: btree, name: "idx_tenants_schema_name"]
    status [type: btree, name: "idx_tenants_status"]
  }
}

Table "usage_tracking" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "resource" "character varying(100)" [not null]
  "current_count" integer [not null, default: 0]
  "last_updated" timestamp [not null, default: `now()`]

  Indexes {
    (tenant_id, resource) [unique, name: "usage_tracking_tenant_id_resource_key"]
    resource [type: btree, name: "idx_usage_tracking_resource"]
    tenant_id [type: btree, name: "idx_usage_tracking_tenant"]
  }
}

Table "user_mfa_settings" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "user_id" uuid [unique, not null]
  "mfa_enabled" boolean [not null, default: false]
  "preferred_method" "character varying(20)" [not null, default: `'email'::charactervarying`]
  "phone_number" "character varying(20)"
  "phone_verified" boolean [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((preferred_method)::text = ANY ((ARRAY['email'::character varying, 'sms'::character varying, 'both'::character varying])::text[]))` [name: 'chk_mfa_method']
  }

  Indexes {
    user_id [type: btree, name: "idx_user_mfa_user_id"]
  }
}

Table "users" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "role_id" uuid [not null]
  "name" "character varying(255)" [not null]
  "email" "character varying(255)" [unique, not null]
  "admin_id" "character varying(50)" [unique]
  "password_hash" text [not null]
  "status" "character varying(20)" [not null, default: `'Active'::charactervarying`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "phone" "character varying(50)"
  "photo_url" text
  "language" "character varying(10)" [default: `'en'::charactervarying`]
  "phone_number" "character varying(20)"
  "country_code" "character varying(5)" [default: `'+91'::charactervarying`]
  "phone_verified" boolean [default: false]
  "phone_verified_at" timestamp
  "preferred_login_method" "character varying(10)" [default: `'email'::charactervarying`]
  "sms_notifications_enabled" boolean [default: true]
  "last_sms_sent_at" timestamp

  Checks {
    `((preferred_login_method)::text = ANY ((ARRAY['email'::character varying, 'phone'::character varying, 'both'::character varying])::text[]))` [name: 'users_preferred_login_method_check']
    `((status)::text = ANY ((ARRAY['Active'::character varying, 'Inactive'::character varying, 'Suspended'::character varying, 'Archived'::character varying])::text[]))` [name: 'users_status_check']
  }

  Indexes {
    admin_id [type: btree, name: "idx_users_admin_id"]
    email [type: btree, name: "idx_users_email"]
    phone_number [type: btree, name: "idx_users_phone_number"]
    phone_verified [type: btree, name: "idx_users_phone_verified"]
    role_id [type: btree, name: "idx_users_role_id"]
    status [type: btree, name: "idx_users_status"]
    tenant_id [type: btree, name: "idx_users_tenant_id"]
  }
}

Table "vendors" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "name" "character varying(255)" [not null]
  "email" "character varying(255)"
  "phone" "character varying(50)"
  "address" text
  "category" "character varying(100)" [not null, default: `'General'::charactervarying`]
  "status" "character varying(20)" [not null, default: `'Active'::charactervarying`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((category)::text = ANY ((ARRAY['General'::character varying, 'Technology'::character varying, 'Services'::character varying, 'Supplies'::character varying, 'Consulting'::character varying, 'Other'::character varying])::text[]))` [name: 'vendors_category_check']
    `((status)::text = ANY ((ARRAY['Active'::character varying, 'Inactive'::character varying])::text[]))` [name: 'vendors_status_check']
  }

  Indexes {
    status [type: btree, name: "idx_vendors_status"]
    tenant_id [type: btree, name: "idx_vendors_tenant_id"]
  }
}

