Table "activities" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "tenant_id" uuid [not null]
  "user_id" uuid [not null]
  "lead_id" uuid
  "type" "character varying(20)" [not null]
  "outcome" "character varying(50)"
  "duration_seconds" integer [default: 0]
  "notes" text
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((outcome)::text = ANY ((ARRAY['Connected'::character varying, 'No Answer'::character varying, 'Interested'::character varying, 'Not Interested'::character varying, 'Converted'::character varying, 'Lost'::character varying])::text[]))` [name: 'activities_outcome_check']
    `((type)::text = ANY ((ARRAY['Call'::character varying, 'Email'::character varying, 'Meeting'::character varying])::text[]))` [name: 'activities_type_check']
  }

  Indexes {
    lead_id [type: btree, name: "idx_activities_lead_id"]
    tenant_id [type: btree, name: "idx_activities_tenant_id"]
    user_id [type: btree, name: "idx_activities_user_id"]
  }
}

Table "campaign_analytics" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
  "campaign_id" uuid [not null]
  "date" date [not null]
  "impressions" integer [not null, default: 0]
  "clicks" integer [not null, default: 0]
  "leads" integer [not null, default: 0]
  "cost" numeric(12,2) [not null, default: 0]
  "revenue" numeric(12,2) [not null, default: 0]
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    campaign_id [type: btree, name: "idx_camp_analytics_campaign"]
    date [type: btree, name: "idx_camp_analytics_date"]
  }
}

Table "campaigns" {
  "id" uuid [pk, not null, default: `public.uuid_generate_v4()`]
