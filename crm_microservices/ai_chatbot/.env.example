# ─── AI Chatbot Microservice Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for chat completions
# Options: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ─── Server ───────────────────────────────────────────────────────────────────
# Port this service listens on
PORT=8003

# ─── Internal Service Communication ──────────────────────────────────────────
# Shared secret with the Node.js backend — must match NODE_BACKEND_SECRET in server/.env
NODE_BACKEND_SECRET=change_this_shared_backend_secret
