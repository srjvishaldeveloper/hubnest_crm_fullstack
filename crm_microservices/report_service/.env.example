# ─── Report Service Microservice Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.

# ─── Database ─────────────────────────────────────────────────────────────────
# Must point to the same PostgreSQL instance as the main backend
# Local:  postgresql://postgres:postgres@localhost:5433/crm_db
# Docker: postgresql://postgres:postgres@postgres:5432/crm_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/crm_db

# ─── Server ───────────────────────────────────────────────────────────────────
# Port this service listens on
PORT=8002

# ─── Internal Service Communication ──────────────────────────────────────────
# Shared secret with the Node.js backend — must match NODE_BACKEND_SECRET in server/.env
NODE_BACKEND_SECRET=change_this_shared_backend_secret
