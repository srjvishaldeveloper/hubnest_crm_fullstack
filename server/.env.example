# ─── Server (Node.js / Express) Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:postgres@localhost:5433/crm_db
# Docker: postgresql://postgres:postgres@postgres:5432/crm_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/crm_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMTP Email (for OTP delivery) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
# Used for campaign bulk sending only — NOT for phone login OTP
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ─── Fast2SMS ─────────────────────────────────────────────────────────────────
# Used for phone login OTP — Indian numbers only
# Get key from: https://fast2sms.com → Dashboard → Dev API
FAST2SMS_API_KEY=your_fast2sms_api_key
# FAST2SMS_SENDER_ID=SRJGLO
# FAST2SMS_TEMPLATE_ID=212208
# OTP_EXPIRY_MINUTES=5

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Internal Service Communication ──────────────────────────────────────────
# Shared secret between backend and microservices — must match NODE_BACKEND_SECRET
# in ai_chatbot and report_service .env files
NODE_BACKEND_SECRET=change_this_shared_backend_secret

# AI Chatbot service URL
# Local:  http://localhost:8003
# Docker: http://host.docker.internal:8003 (Windows/Mac) or http://chatbot:8003 (Linux)
CHATBOT_URL=http://host.docker.internal:8003

# Report service URL
# Local:  http://localhost:8002
# Docker: http://host.docker.internal:8002 (Windows/Mac) or http://reports:8002 (Linux)
REPORT_SERVICE_URL=http://host.docker.internal:8002

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Comma-separated list of Gmail addresses allowed to log in via Google OAuth.
# Leave blank to allow any Google account that has a matching user in the DB.
GOOGLE_OAUTH_ALLOWED_EMAILS=

# ─── Meta / Facebook / WhatsApp ───────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
# Required scopes: ads_read, ads_management, pages_manage_ads, whatsapp_business_management
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ─── Payment Gateway ──────────────────────────────────────────────────────────
# AES-256 key for encrypting tenant payment credentials stored in DB
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string_for_production

# HubNest's OWN Razorpay/Stripe keys — for tenant subscription billing to HubNest ONLY
# These are NEVER used for tenant customer invoice payments (those use per-tenant DB keys)
HUBNEST_RAZORPAY_KEY_ID=rzp_live_your_hubnest_key_id
HUBNEST_RAZORPAY_KEY_SECRET=your_hubnest_razorpay_secret
HUBNEST_STRIPE_SECRET_KEY=sk_live_your_hubnest_stripe_secret
HUBNEST_STRIPE_PUBLISHABLE_KEY=pk_live_your_hubnest_stripe_publishable

# ─── Super Admin ──────────────────────────────────────────────────────────────
# Master super-admin account email — protected from bulk deletion operations
SUPER_ADMIN_EMAIL=your_superadmin_email@example.com
