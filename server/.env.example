# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:postgres@localhost:5432/crm_db
# Docker: postgresql://postgres:postgres@postgres:5432/crm_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP (email for OTP delivery) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300

# ── Twilio (SMS OTP delivery) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Comma-separated list of Gmail addresses allowed to log in via Google OAuth
# Leave blank to allow any Google account that has a matching user in the DB
GOOGLE_OAUTH_ALLOWED_EMAILS=sandipsharm4322@gmail.com
