# Server
PORT=5000
NODE_ENV=development

# Database
# Local:  postgresql://postgres:postgres@localhost:5433/crm_db
# Docker: postgresql://postgres:postgres@postgres:5432/crm_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/crm_db

# Redis
# Local:  redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# JWT
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP email for OTP delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password

# OTP
OTP_EXPIRY_SECONDS=300

# Twilio SMS - used for campaign bulk sending only, not phone login OTP
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Fast2SMS - phone login OTP for Indian numbers only
# Get key from: https://fast2sms.com
FAST2SMS_API_KEY=your_fast2sms_api_key
# FAST2SMS_SENDER_ID=SRJGLO
# FAST2SMS_TEMPLATE_ID=212208
# OTP_EXPIRY_MINUTES=5

# Frontend
FRONTEND_URL=http://localhost:3000

# Internal service communication
NODE_BACKEND_SECRET=change_this_shared_backend_secret
CHATBOT_URL=http://host.docker.internal:8003

# Google OAuth
# Get from Google Cloud Console: APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Comma-separated list of Gmail addresses allowed to log in via Google OAuth.
# Leave blank to allow any Google account that has a matching user in the DB.
GOOGLE_OAUTH_ALLOWED_EMAILS=

# ─── PAYMENT GATEWAY ──────────────────────────────────────────────────────────
# AES-256 key for encrypting tenant payment credentials in DB (any 32+ char string)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string_for_production

# HubNest's OWN payment keys — used ONLY for tenant subscription billing to HubNest
# These are NEVER used for tenant customer invoice payments (those use per-tenant DB keys)
HUBNEST_RAZORPAY_KEY_ID=rzp_live_your_hubnest_key_id
HUBNEST_RAZORPAY_KEY_SECRET=your_hubnest_razorpay_secret
HUBNEST_STRIPE_SECRET_KEY=sk_live_your_hubnest_stripe_secret
HUBNEST_STRIPE_PUBLISHABLE_KEY=pk_live_your_hubnest_stripe_publishable
